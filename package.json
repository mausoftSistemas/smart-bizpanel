{
  "name": "bizventas-api",
  "version": "1.0.0",
  "description": "API REST backend para BizVentas - Puente entre app Flutter y ERPs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "npx prisma db seed"
  },
  "dependencies": {
    "express": "^4.21.0",
    "@prisma/client": "^6.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.0",
    "dotenv": "^16.4.0",
    "winston": "^3.15.0",
    "node-cron": "^3.0.0",
    "zod": "^3.23.0",
    "axios": "^1.7.0",
    "uuid": "^10.0.0",
    "multer": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/node-cron": "^3.0.0",
    "@types/multer": "^1.4.0",
    "@types/uuid": "^10.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
