generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══ SUPER ADMIN ═══

model SuperAdmin {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  nombre        String
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?
}

// ═══ MULTI-TENANT ═══

model Tenant {
  id              String   @id @default(uuid())
  codigo          String   @unique
  razonSocial     String
  cuit            String?
  email           String
  plan            String   @default("basico")
  maxVendedores   Int      @default(5)
  estado          String   @default("activo")

  // Módulos habilitados
  moduloGps       Boolean  @default(false)
  moduloMp        Boolean  @default(false)
  moduloFirma     Boolean  @default(false)
  moduloEmail     Boolean  @default(false)

  // Config ERP
  erpTipo         String   @default("standalone") // standalone, sap_b1, tango, custom
  erpUrl          String?
  erpCredenciales Json?    // encrypted
  erpMapping      Json?    // field mapping JSON

  // White Label
  logo            String?
  colorPrimario   String   @default("#1565C0")
  colorSecundario String   @default("#00E5FF")
  nombreApp       String   @default("BizVentas")

  // Contacto de la empresa
  contactoNombre    String?
  contactoTelefono  String?
  contactoEmail     String?
  notas             String?    // notas internas sobre este cliente

  // Facturación (cobro al cliente)
  planPrecio        Float    @default(0)
  planMoneda        String   @default("USD")
  planPeriodicidad  String   @default("mensual") // mensual, anual
  proximoVencimiento DateTime?
  diasMora          Int      @default(0)

  // Métricas de uso (cache, actualizadas periódicamente)
  cantidadUsuarios     Int   @default(0)
  cantidadProductos    Int   @default(0)
  cantidadClientes     Int   @default(0)
  cantidadPedidosMes   Int   @default(0)
  ultimaActividad      DateTime?
  almacenamientoMb     Float @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  productos       Producto[]
  clientes        Cliente[]
  pedidos         Pedido[]
  cobranzas       Cobranza[]
  rutas           Ruta[]
  politicas       PoliticaComercial[]
  config          TenantConfig?
}

model TenantConfig {
  id                    String  @id @default(uuid())
  tenantId              String  @unique
  tenant                Tenant  @relation(fields: [tenantId], references: [id])

  // Moneda y formato
  moneda                String  @default("ARS")
  formatoFecha          String  @default("dd/MM/yyyy")
  ivaDefault            Float   @default(21)

  // Pedidos
  montoMinimoPedido     Float   @default(0)
  montoMaximoPedido     Float   @default(0)
  permitePedidoSinStock Boolean @default(true)
  requiereFirma         Boolean @default(false)

  // Cobranza
  permiteEfectivo       Boolean @default(true)
  permiteCheque         Boolean @default(true)
  permiteTransferencia  Boolean @default(true)
  permiteBilletera      Boolean @default(true)
  permiteMercadoPago    Boolean @default(false)

  // Jornada
  jornadaObligatoria    Boolean @default(true)
  horaInicioMin         String  @default("06:00")
  horaInicioMax         String  @default("09:00")
  horaFinMax            String  @default("21:00")
  requiereGeoInicio     Boolean @default(false)

  // Descuentos
  maxDescuentoVendedor  Float   @default(10)
  maxDescuentoSupervisor Float  @default(20)

  // Devoluciones
  diasLimiteDevolucion  Int     @default(30)
  devolucionRequiereFoto Boolean @default(true)
  devolucionRequiereAprobacion Boolean @default(true)

  // GPS
  trackingIntervaloSeg  Int     @default(30)
  trackingActivo        Boolean @default(true)

  updatedAt             DateTime @updatedAt
}

// ═══ USUARIOS ═══

model User {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  email         String
  passwordHash  String
  nombre        String
  rol           String   // admin, supervisor, vendedor, deposito, repartidor
  activo        Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())

  // Campos ERP
  codigoVendedor  String?   // código del vendedor en el ERP (004, 029, etc.)
  codigoPersona   String?   // PERSONA del ERP
  codigoZona      String?   // COD_ZONA

  pedidos       Pedido[]
  cobranzas     Cobranza[]
  jornadas      Jornada[]
  visitas       Visita[]

  @@unique([tenantId, email])
}

// ═══ CATÁLOGO ═══

model Producto {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  codigo        String
  nombre        String
  descripcion   String?
  categoria     String?
  marca         String?
  precioLista   Float
  moneda        String   @default("ARS")
  stockBulto    Float    @default(0)
  stockUnidad   Float    @default(0)
  equivalencia  Float    @default(1)
  unidadMedida  String   @default("UN")
  ivaPorcentaje Float    @default(21)
  pesoKg        Float    @default(0)
  codigoBarras  String?
  imagenUrl     String?
  activo        Boolean  @default(true)
  erpId         String?  // ID en el ERP externo
  updatedAt     DateTime @updatedAt

  // Campos ERP
  codigoRubro       String?   // CODIGO_RUBRO del ERP
  nombreRubro       String?   // NOMBRE_RUBRO
  codigoSubrubro    String?   // COD_SUBRUBRO
  nombreSubrubro    String?   // NOMBRE_SUBRUBRO
  codigoDeposito    String?   // COD_DEPOSITO
  nombreDeposito    String?   // NOMBRE_DEPOSITO
  listaPrecioId     String?   // LISTA_PRECIO (qué lista tiene)
  nombreListaPrecio String?   // NOMBRE_LISTA
  impuestoInterno   Float     @default(0)   // %IMP_INTERNO
  costoNeto         Float     @default(0)   // COSTO_NETO
  codigoEstado      String?   // COD_ESTADO del ERP
  resumenUniMedida  String?   // RESUMEN_UNI_MEDIDA (abreviatura)
  codigoUnidad      String?   // COD_UNIDAD
  nombreUnidad      String?   // NOMBRE_UNI_MEDIDA completo

  @@unique([tenantId, codigo])
}

// ═══ CLIENTES ═══

model Cliente {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  codigo          String
  nombre          String
  direccion       String?
  ciudad          String?
  provincia       String?
  telefono        String?
  email           String?
  cuit            String?
  condicionIva    String?
  condicionVenta  String?
  listaPrecioId   String?
  saldoCuenta     Float    @default(0)
  limiteCredito   Float    @default(0)
  latitud         Float?
  longitud        Float?
  vendedorId      String?
  rutaId          String?
  canal           String?
  segmento        String?
  activo          Boolean  @default(true)
  erpId           String?
  updatedAt       DateTime @updatedAt

  // Campos ERP
  codigoPostal    String?   // COD_POSTAL
  tipoDni         String?   // COD_DNI (tipo documento)
  codigoArca      String?   // COD_ARCA (código AFIP/ARCA)
  codigoEstado    String?   // COD_ESTADO del ERP

  pedidos         Pedido[]
  cobranzas       Cobranza[]
  cuentaCorriente CuentaCorriente[]
  telefonos       ClienteTelefono[]

  @@unique([tenantId, codigo])
}

// ═══ PEDIDOS ═══

model Pedido {
  id              String       @id @default(uuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  clienteId       String
  cliente         Cliente      @relation(fields: [clienteId], references: [id])
  vendedorId      String
  vendedor        User         @relation(fields: [vendedorId], references: [id])
  fecha           DateTime
  estado          String       @default("pendiente")
  tipoComprobante String?
  subtotal        Float        @default(0)
  descuentoGlobal Float        @default(0)
  total           Float        @default(0)
  observaciones   String?
  jornadaId       String?
  appLocalId      String?      // UUID que mandó la app
  erpId           String?      // ID en el ERP
  erpSynced       Boolean      @default(false)
  erpError        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Campos ERP
  horaInicio          String?   // HORA_PEDIDO_INI (hhmmss)
  horaFin             String?   // HORA_PEDIDO_FIN
  fechaEntrega        DateTime? // FECHA_ENTREGA solicitada
  netoTotal           Float     @default(0)  // NETO_PEDIDO (total sin IVA)
  cantidadItems       Int       @default(0)  // CANTID_ITEMS
  latitud             Float?    // GPS al crear el pedido
  longitud            Float?    // GPS al crear el pedido
  codigoEstado        String    @default("0") // COD_ESTADO
  condicionVtaCodigo  String?   // código de condición de venta
  listaPrecioUsada    String?   // qué lista de precio se usó

  items           PedidoItem[]
}

model PedidoItem {
  id                  Int     @id @default(autoincrement())
  pedidoId            String
  pedido              Pedido  @relation(fields: [pedidoId], references: [id])
  productoId          String
  productoCodigo      String
  productoNombre      String
  cantidad            Float
  unidadTipo          String  @default("unidad")
  precioUnitario      Float
  descuentoPorcentaje Float   @default(0)
  subtotal            Float

  // Campos ERP
  codigoCombo     String?   // NCOMBO
  precioNeto      Float     @default(0)  // PRECIO_NETO (precio sin IVA)
  listaPrecio     String?   // LISTA_PRECIO
  bultoUnidad     Int       @default(1)  // 1=bulto, 2=unidad (formato ERP)
}

// ═══ COBRANZA ═══

model Cobranza {
  id            String          @id @default(uuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  clienteId     String
  cliente       Cliente         @relation(fields: [clienteId], references: [id])
  vendedorId    String
  vendedor      User            @relation(fields: [vendedorId], references: [id])
  fecha         DateTime
  total         Float
  estado        String          @default("confirmado")
  appLocalId    String?
  erpId         String?
  erpSynced     Boolean         @default(false)
  createdAt     DateTime        @default(now())

  // Campos ERP
  horaInicio      String?   // HORA_INICIO (hhmmss)
  horaFin         String?   // HORA_FIN
  numeroRecibo    String?   // NRO_RECIBO
  latitud         Float?    // GPS al cobrar
  longitud        Float?    // GPS al cobrar
  codigoVendedor  String?   // COD_VENDEDOR del ERP

  medios          CobranzaMedio[]
  imputaciones    CobranzaImputacion[]
}

model CobranzaMedio {
  id          Int      @id @default(autoincrement())
  cobranzaId  String
  cobranza    Cobranza @relation(fields: [cobranzaId], references: [id])
  tipo        String   // efectivo, cheque, transferencia, billetera, tarjeta, retencion, mp
  monto       Float
  moneda      String   @default("ARS")
  datos       Json     // campos específicos del medio

  // Campos ERP explícitos (además del JSON)
  codigoMedioPago     String?   // COD_MEDIO_PAGO del ERP
  numeroReferencia    String?   // NRO_REFERENCIA_PAGO
  plazaCheque         String?   // PLAZA_CHEQUE
  fechaEmision        DateTime? // FECHA_EMISION del cheque
  fechaVencimiento    DateTime? // FECHA_VTO del cheque
  cotizacion          Float     @default(1)  // tipo de cambio
  cuitAcreedor        String?   // CUIT del librador del cheque
  titularTarjeta      String?   // TITULAR_TARJETA
  codigoAutorizacion  String?   // COD_AUTORIZA_TARJETA
  codigoLote          String?   // COD_LOTE
  cuotas              Int?      // CUOTAS tarjeta
  numeroCupon         String?   // NRO_CUPON
}

model CobranzaImputacion {
  id                Int      @id @default(autoincrement())
  cobranzaId        String
  cobranza          Cobranza @relation(fields: [cobranzaId], references: [id])
  tipoComprobante   String   // FAC, NC, ND
  sucursal          String   // 0001, 0003
  numeroComprobante String   // 00008193
  importeCobrado    Float    // monto que se aplicó a este comprobante
  numeroCuota       Int      @default(1)
  letraComprobante  String?  // A, B, C, X
}

// ═══ CUENTA CORRIENTE ═══

model CuentaCorriente {
  id              String   @id @default(uuid())
  tenantId        String
  clienteId       String
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  tipoMovimiento  String   // factura, nota_credito, nota_debito, recibo
  numero          String?
  fecha           DateTime
  fechaVencimiento DateTime?
  debe            Float    @default(0)
  haber           Float    @default(0)
  saldo           Float    @default(0)
  estado          String   @default("pendiente")
  erpId           String?
  createdAt       DateTime @default(now())

  // Campos ERP
  sucursal          String?   // SUCURSAL (punto de venta)
  tipoLetra         String?   // TIPO_LETRA (A, B, C, X)
  cuotas            Int       @default(1)
  vendedorId        String?   // NRO_VENDEDOR
  importeCobrado    Float     @default(0)  // IMP_COBRADO (lo que ya se cobró)
  importeFactura    Float     @default(0)  // IMP_FACTURA (monto original)
  saldoComprobante  Float     @default(0)  // SALDO_CMPTE
  codigoEstado      String?
}

// ═══ JORNADAS Y VISITAS ═══

model Jornada {
  id                String   @id @default(uuid())
  tenantId          String
  vendedorId        String
  vendedor          User     @relation(fields: [vendedorId], references: [id])
  fecha             DateTime
  horaInicio        DateTime
  horaFin           DateTime?
  estado            String   @default("activa")
  inicioLat         Float?
  inicioLng         Float?
  finLat            Float?
  finLng            Float?
  clientesPlan      Int      @default(0)
  clientesVisitados Int      @default(0)
  totalVendido      Float    @default(0)
  totalCobrado      Float    @default(0)
  kmRecorridos      Float    @default(0)
  appLocalId        String?

  visitas           Visita[]
  gpsPoints         GpsPoint[]
}

model Visita {
  id          String   @id @default(uuid())
  jornadaId   String
  jornada     Jornada  @relation(fields: [jornadaId], references: [id])
  clienteId   String
  vendedorId  String
  vendedor    User     @relation(fields: [vendedorId], references: [id])
  fechaHora   DateTime
  tipo        String   // pedido, no_compra, cobranza, visita, devolucion
  resultado   String?
  pedidoId    String?
  monto       Float    @default(0)
  latitud     Float?
  longitud    Float?
  appLocalId  String?

  // Campos ERP
  codigoZona        String?   // NRO_ZONA
  codigoNoCompra    String?   // COD_NO_COMPRA (código del motivo)
  horaRegistro      String?   // hora separada de la fecha (hhmmss)
  codigoVendedor    String?   // código del vendedor en el ERP
  codigoCliente     String?   // código del cliente en el ERP (para el export)
}

// ═══ GPS ═══

model GpsPoint {
  id          Int      @id @default(autoincrement())
  jornadaId   String
  jornada     Jornada  @relation(fields: [jornadaId], references: [id])
  vendedorId  String
  latitud     Float
  longitud    Float
  velocidad   Float?
  timestamp   DateTime
  bateria     Int?
}

// ═══ RUTAS ═══

model Ruta {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  nombre      String
  diaSemana   Int?
  vendedorId  String?

  clientes    RutaCliente[]
}

model RutaCliente {
  id        Int    @id @default(autoincrement())
  rutaId    String
  ruta      Ruta   @relation(fields: [rutaId], references: [id])
  clienteId String
  orden     Int    @default(0)

  // Campos ERP
  horaVisita  String?   // HORAVISITA (hora sugerida)
}

// ═══ DEVOLUCIONES ═══

model Devolucion {
  id              String   @id @default(uuid())
  tenantId        String
  clienteId       String
  vendedorId      String
  pedidoOriginalId String?
  facturaNumero   String?
  tipo            String   // devolucion_total, devolucion_parcial, cambio, reclamo
  estado          String   @default("pendiente")
  total           Float    @default(0)
  motivoGeneral   String?
  aprobadaPor     String?
  fechaAprobacion DateTime?
  ncNumero        String?
  erpId           String?
  erpSynced       Boolean  @default(false)
  appLocalId      String?
  createdAt       DateTime @default(now())

  items           DevolucionItem[]
}

model DevolucionItem {
  id              Int        @id @default(autoincrement())
  devolucionId    String
  devolucion      Devolucion @relation(fields: [devolucionId], references: [id])
  productoId      String
  productoCodigo  String
  productoNombre  String
  cantidadDevuelta Float
  precioUnitario  Float
  motivo          String?
  lote            String?
  subtotal        Float
}

// ═══ POLÍTICAS COMERCIALES ═══

model PoliticaComercial {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  nombre      String
  evento      String
  condiciones Json
  accion      String
  accionParams Json?
  mensaje     String?
  prioridad   Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ═══ PRECIOS ESPECIALES POR CLIENTE ═══

model PrecioCliente {
  id          String   @id @default(uuid())
  tenantId    String
  clienteId   String
  productoId  String
  precio      Float
  descuento   Float    @default(0)
  moneda      String   @default("ARS")
  vigenciaDesde DateTime?
  vigenciaHasta DateTime?
  activo      Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, clienteId, productoId])
}

// ═══ CATÁLOGOS ═══

model CondicionVenta {
  id            String    @id @default(uuid())
  tenantId      String
  codigo        String
  nombre        String
  diasPlazo     Int       @default(0)
  activo        Boolean   @default(true)
  updatedAt     DateTime  @updatedAt

  // Campos ERP
  descripcion   String?
  moneda        String    @default("ARS")
  recargo       Float     @default(0)     // %RECARGO
  bonificacion  Float     @default(0)     // %BONIFICACION
  contado       Float     @default(0)     // %CONTADO (descuento por contado)
  observacion   String?
  ventaFija     Boolean   @default(false) // VTA_FIJA
  fechaVto      DateTime?                 // FECHA_VTO
  limiteCredito Float     @default(0)     // LIMITE_CREDITO default de esta condición
  codigoEstado  String?

  @@unique([tenantId, codigo])
}

model MotivoNoCompra {
  id            String   @id @default(uuid())
  tenantId      String
  codigo        String
  descripcion   String
  activo        Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  // Campos ERP
  codigoEstado  String?

  @@unique([tenantId, codigo])
}

// ═══ OBJETIVOS ═══

model Objetivo {
  id            String   @id @default(uuid())
  tenantId      String
  vendedorId    String?  // null = aplica a todos
  tipo          String   // general, focal
  nombre        String
  metrica       String   // monto_venta, cantidad_pedidos, clientes_visitados, cobranza, mix_productos
  valorObjetivo Float
  valorActual   Float    @default(0)
  productoId    String?  // para objetivos focales de producto
  categoriaId   String?  // para objetivos focales de categoría
  periodoInicio DateTime
  periodoFin    DateTime
  activo        Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

// ═══ MENSAJES / NOTIFICACIONES ═══

model Mensaje {
  id          String   @id @default(uuid())
  tenantId    String
  vendedorId  String?  // null = broadcast a todos
  titulo      String
  cuerpo      String
  tipo        String   @default("info") // info, alerta, urgente
  leido       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══ BILLETERAS VIRTUALES ═══

model Billetera {
  id          String   @id @default(uuid())
  tenantId    String
  nombre      String
  alias       String?
  cbu         String?
  activo      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ═══ DENOMINACIONES (PARA ARQUEO DE CAJA) ═══

model Denominacion {
  id          String   @id @default(uuid())
  tenantId    String
  tipo        String   // billete, moneda
  valor       Float
  moneda      String   @default("ARS")
  activo      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ═══ IMPORT LOG ═══

model ImportLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  fileName    String
  entityType  String   // productos, clientes, facturas, precios
  totalRows   Int
  imported    Int      @default(0)
  updated     Int      @default(0)
  skipped     Int      @default(0)
  errors      Int      @default(0)
  errorDetail Json?    // array de { row, error, data }
  mapping     Json?    // mapping usado en la importación
  createdAt   DateTime @default(now())
}

// ═══ MAPEO GUARDADO (IA + manual) ═══

model MappingGuardado {
  id               String   @id @default(uuid())
  tenantId         String
  entityType       String
  nombre           String
  columnasArchivo  Json     // array de strings
  huella           String   // sha256 de columnas ordenadas
  mapping          Json     // { campoSistema: "columnaArchivo" }
  defaultValues    Json?
  opciones         Json?
  vecesUsado       Int      @default(1)
  creadoPorIA      Boolean  @default(true)
  confirmado       Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, entityType, huella])
}

// ═══ INTERCAMBIO ERP (archivos TXT/CSV) ═══

model IntercambioConfig {
  id        String   @id @default(uuid())
  tenantId  String
  nombre    String   // "Configuración Tango", "Config SAP", etc.
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  archivos ArchivoConfig[]
}

model ArchivoConfig {
  id              String             @id @default(uuid())
  intercambioId   String
  intercambio     IntercambioConfig  @relation(fields: [intercambioId], references: [id], onDelete: Cascade)

  direccion       String   // "import" o "export"
  nombre          String   // "Articulos", "Cabecera Pedidos", etc.
  nombreArchivo   String   // "ARTICULOS.TXT", "CabeceraPedidos.txt"

  // Qué entidad del sistema mapea
  entidad         String   // productos, clientes, clientesTelefono, condicionesVenta,
                           // cuentaCorriente, motivosNoCompra, rutas, vendedores,
                           // pedidosCabecera, pedidosDetalle, cobranzasCabecera,
                           // cobranzasDetallePagos, cobranzasDocImputados, excusas

  // Relación padre-hijo (cabecera → detalle)
  esDetalle       Boolean  @default(false)
  archivoPadreId  String?
  campoRelacion   String?  // campo que vincula detalle con cabecera

  // Formato del archivo
  formatoArchivo  String   @default("txt")     // txt, csv, json, xlsx
  separador       String   @default(";")       // ; , | \t
  encoding        String   @default("latin1")  // latin1, utf-8, windows-1252
  tieneEncabezado Boolean  @default(true)
  saltarFilas     Int      @default(0)
  formatoFecha    String   @default("yyyyMMdd")
  separadorDecimal String  @default(".")

  // Mapeo de columnas (JSON)
  mapeoColumnas   Json     // import: { campoLocal: "COL_ARCHIVO" }, export: { COL_ERP: "campoLocal" }

  // Para import
  valoresDefault  Json?
  actualizarExist Boolean  @default(true)
  campoUnico      String?  @default("codigo")

  // Para export
  soloNuevos      Boolean  @default(true)
  filtroEstado    String?

  orden           Int      @default(0)
  activo          Boolean  @default(true)
}

model IntercambioLog {
  id             String   @id @default(uuid())
  tenantId       String
  direccion      String   // "import" o "export"
  usuario        String
  estado         String   @default("ok")

  // Detalle por archivo
  archivos       Json     // [{ nombre, entidad, registros, actualizados, errores }]
  erroresDetalle Json?

  // Para export: ruta del ZIP generado (para redescargar)
  archivoZipPath String?

  createdAt      DateTime @default(now())
}

model ClienteTelefono {
  id            Int     @id @default(autoincrement())
  tenantId      String
  clienteId     String
  cliente       Cliente @relation(fields: [clienteId], references: [id])
  tipo          String  @default("telefono") // telefono, celular, fax, whatsapp
  numero        String
  contacto      String? // nombre de la persona
  principal     Boolean @default(false)
  codigoControl String? // COD_CONTROL del ERP
}

// ═══ SYNC LOG ═══

model SyncLog {
  id          Int      @id @default(autoincrement())
  tenantId    String
  userId      String
  direction   String   // push, pull
  entityType  String   // productos, clientes, pedidos, etc.
  recordCount Int      @default(0)
  status      String   // success, error
  errorDetail String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
}
